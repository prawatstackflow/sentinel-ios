<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Copy this file to DemoSecrets.plist (git-ignored) and fill in the key.
         Powers the demo app's "Start Demo Session" button. -->

    <!-- Tenant API key for minting demo sessions (POST /sessions). Mint one in
         the admin console for the sandbox tenant. DEMO ONLY — never ship an API
         key in a real client app; keep it server-side. Empty disables the button. -->
    <key>DEMO_API_KEY</key>
    <string></string>

    <!-- Where to mint the session (no trailing /sessions). Local LAN by default;
         use https://test-api-identity.finvasia.com for the deployed sandbox. -->
    <key>DEMO_API_BASE_URL</key>
    <string>https://10.10.10.51/api</string>

    <!-- Origin of the hosted verification flow loaded in the WebView. -->
    <key>DEMO_HOSTED_FLOW_BASE_URL</key>
    <string>https://10.10.10.51</string>
</dict>
</plist>
